{
  "ci": {
    "collect": {
      "staticDistDir": "dist",
      "url": ["http://localhost/"]
    },
    "assert": {
      "assertions": {
        "categories:performance": ["warn", { "minScore": 0.9 }],
        "categories:accessibility": ["error", { "minScore": 0.9 }],
        "categories:best-practices": ["error", { "minScore": 0.9 }],
        "categories:pwa": ["warn", { "minScore": 0.5 }]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
